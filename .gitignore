# Build trees (out-of-tree)
/build/
/cmake-build-*/
/out/
/build-*/

# CMake generated from accidental in-source configures.
# Prefer out-of-tree builds; do not use a blanket *.cmake (would hide future
# cmake/*.cmake modules and package-config templates intended for the repo).
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
compile_commands.json
CTestTestfile.cmake
_deps/

# Object / library artifacts
*.o
*.a
*.so
*.so.*
*.dylib
*.dll
*.exe
*.out

# IDE / editor
.idea/
.vscode/
*.swp
*.swo
*~
.cache/

# OS
.DS_Store
Thumbs.db

# Test / coverage
Testing/
*.gcda
*.gcno
*.gcov
coverage/
